# --- StyleGlance configuration ---
# Copy this file to ".env.local" and fill in your key.
# Without a key the app runs in DEMO mode (placeholder images).

# Google Gemini API key (https://aistudio.google.com/apikey)
# This powers the "render me in this look" image generation.
GEMINI_API_KEY=

# Optional: override the image model if Google renames it.
# Default is the current "Nano Banana" image model.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
