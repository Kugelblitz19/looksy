# --- Looksy configuration ---
# Copy this file to ".env.local" and fill in your key.
# Without a key the app runs in DEMO mode (placeholder images).

# --- Supabase (database + auth) ---
# Create a free project at https://supabase.com, then open
# Project Settings → API and copy these three values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only "master" key — NEVER exposed to the browser. Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=

# (Legacy) secret for the old cookie auth — retired once Supabase Auth is live.
SESSION_SECRET=

# Google Gemini API key (https://aistudio.google.com/apikey)
# This powers the "render me in this look" image generation.
GEMINI_API_KEY=

# Optional: override the image model if Google renames it.
# Default is the current "Nano Banana" image model.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional: model used to read garments out of a generated look (Shop the Look).
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Optional: output aspect ratio for generated looks (full-body portrait by
# default). Supported: 3:4, 4:5, 2:3, 9:16, 1:1, etc.
GEMINI_ASPECT_RATIO=4:5

# --- Monetization (Shop the Look affiliate links) ---
# Paste your affiliate network's deep-link template, with the literal {url}
# placeholder where the target merchant URL goes. Leave blank and links still
# work — they're just not monetized yet.
#
# Admitad (recommended: open signup, programmatic deeplink API, covers
# Myntra/Ajio/Flipkart/Nykaa). Replace <campaign> with your campaign id:
# LOOKSY_AFFILIATE_TEMPLATE=https://ad.admitad.com/g/<campaign>/?ulp={url}
#
# Cuelinks (broad coverage, auto-link; replace XXXXX with your cid):
# LOOKSY_AFFILIATE_TEMPLATE=https://linksredirect.com/?cid=XXXXX&source=looksy&url={url}
LOOKSY_AFFILIATE_TEMPLATE=

# Shortcut: if you only have an Amazon Associates account (the easiest program
# to join — free signup at https://affiliate-program.amazon.in), just set
# AMAZON_PARTNER_TAG below. Every Amazon link is then auto-stamped with ?tag=,
# even with no aggregator template here and no Creators API. The other three
# merchants stay unmonetized until you add an aggregator template above.

# --- Product cards (Shop the Look v2) ---
# Which product-data provider powers the cards:
#   searchlinks (default) — merchant search-link chips, no API needed
#   mock                  — fake demo products (great for trying the card UI)
#   amazon                — real products via the Amazon Creators API (below)
LOOKSY_PRODUCT_PROVIDER=searchlinks

# Amazon Creators API (only needed when LOOKSY_PRODUCT_PROVIDER=amazon).
# Requires an approved Amazon Associates India account. NOTE: Amazon gates
# Creators API access behind ~10 qualifying sales in a trailing 30 days, so a
# brand-new account may not have API access until it drives some sales.
AMAZON_CREATORS_CLIENT_ID=
AMAZON_CREATORS_CLIENT_SECRET=
AMAZON_PARTNER_TAG=
# Optional overrides:
# AMAZON_MARKETPLACE=www.amazon.in
# AMAZON_CREATORS_HOST=https://creatorsapi.amazon
# AMAZON_OAUTH_TOKEN_URL=https://api.amazon.com/auth/o2/token
# AMAZON_CREATORS_SCOPE=

# --- Google Play (Android TWA) ---
# After you package the PWA (PWABuilder.com) and upload to Play Console, paste
# the app's package name + signing-cert SHA-256 here so /.well-known/assetlinks
# .json verifies the app (removes the browser URL bar). Get the fingerprint from
# Play Console → App integrity → App signing (and the one PWABuilder shows).
# Multiple fingerprints can be comma-separated.
TWA_PACKAGE_NAME=
TWA_CERT_SHA256=
